/*--------------------------------*- C++ -*----------------------------------*\
| Generated by OpenFOAM RC CFD GUI                                           |
\*---------------------------------------------------------------------------*/
FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      controlDict;
}

application      foamRun;
solver           incompressibleFluid;
startFrom        startTime;
startTime        0;
stopAt           endTime;
endTime          {{ end_time }};
deltaT           1;
writeControl     timeStep;
writeInterval    {{ write_interval }};
purgeWrite       3;
writeFormat      ascii;
writePrecision   6;
writeCompression off;
timeFormat       general;
timePrecision    6;
runTimeModifiable true;

functions
{
    forceCoeffs
    {
        type            forceCoeffs;
        libs            ( "libforces.so" );
        writeControl    timeStep;
        writeInterval   {{ write_interval }};
        patches         ( aircraft );
        rho             rhoInf;
        rhoInf          {{ rho }};
        liftDir         ( {{ lift_x }} 0 {{ lift_z }} );
        dragDir         ( {{ drag_x }} 0 {{ drag_z }} );
        pitchAxis       ( 0 1 0 );
        magUInf         {{ U_mag }};
        lRef            {{ lRef }};
        Aref            {{ Aref }};
        CofR            ( 0 0 0 );
    }

    wallShearStress
    {
        type            wallShearStress;
        libs            ( "libfieldFunctionObjects.so" );
        writeControl    writeTime;
        patches         ( aircraft );
    }

    yPlus
    {
        type            yPlus;
        libs            ( "libfieldFunctionObjects.so" );
        writeControl    writeTime;
        patches         ( aircraft );
    }

    residuals
    {
        type            solverInfo;
        libs            ( "libutilityFunctionObjects.so" );
        writeControl    timeStep;
        writeInterval   1;
    }
}
